# === tianbot_ws .gitignore ===
# Quantization workspace: keeps scripts, configs, manifests, quant outputs
# Excludes: SDK installers, venvs, calibration data, caches

# Python virtual environment
.venv_oe_py310/

# Open Explorer SDK (296 MB) and DDK runtime
open_explorer_x5/
.horizon/

# Checker intermediates (regenerable)
.hb_check/

# Calibration data inside models/ (regenerable, heavyweight)
models/*/calibration/

# hb_mapper intermediate ONNX inside output/ (regenerable)
models/*/output/*.onnx

# Agent/IDE caches
.claude/
.codex/
.vscode-server/

# Python cache
__pycache__/
*.pyc
*.pyo
.cache/

# Garbage files from malformed pip commands
=*
